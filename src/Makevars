## Use RcppArmadillo for C++ compilation
PKG_CPPFLAGS = `"${R_HOME}/bin/Rscript" -e "RcppArmadillo:::CxxFlags()"`

## Link against the same LAPACK/BLAS libraries that R was built with
PKG_LIBS = `"${R_HOME}/bin/Rscript" -e "RcppArmadillo:::LdFlags()"` \
            $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
